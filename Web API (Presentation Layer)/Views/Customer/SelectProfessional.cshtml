@model Application.Wrappers.PagedResult<Application.DTOs.WorkerDto>
@{
    var searchDto = ViewData["SearchParameters"] as Application.DTOs.WorkerSearchDto ?? new Application.DTOs.WorkerSearchDto();
}
@* Select a Professional – Arabic (RTL) *@
@* Bundle: Customer & Booking + Worker | Layout assumes _Layout loads TailwindCSS + main-theme.css *@

<div class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden" dir="rtl">
    <div class="layout-container flex h-full grow flex-col">
        <header class="flex items-center justify-between whitespace-nowrap border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-6 py-4 md:px-40">
            <div class="flex items-center gap-4 text-primary">
                <div class="size-8 flex items-center justify-center bg-primary rounded-lg text-white"><span class="material-symbols-outlined">build</span></div>
                <h2 class="text-slate-900 dark:text-slate-100 text-xl font-bold leading-tight tracking-tight">صلاحلي</h2>
            </div>
            <div class="flex gap-4">
                <button class="flex size-10 items-center justify-center rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300"><span class="material-symbols-outlined">notifications</span></button>
                <button class="flex size-10 items-center justify-center rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300"><span class="material-symbols-outlined">menu</span></button>
            </div>
        </header>
        <main class="flex-1 px-4 py-8 md:px-40">
            <div class="max-w-[960px] mx-auto flex flex-col gap-8">
                <div class="flex flex-col gap-3 p-4 bg-white dark:bg-slate-900 rounded-xl shadow-sm">
                    <div class="flex justify-between items-center"><p class="font-bold">الخطوة 3 من 4</p><p class="text-primary text-sm font-bold">75%</p></div>
                    <div class="h-2 w-full bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden"><div class="h-full bg-primary rounded-full" style="width: 75%;"></div></div>
                </div>
                <div class="flex flex-col gap-2">
                    <h1 class="text-3xl font-bold tracking-tight">اختر الفني المناسب</h1>
                    <p class="text-slate-500">فنيون متاحون الآن بالقرب منك</p>
                </div>
                <!-- Filter Form -->
                <form asp-action="Index" asp-controller="Customer" method="get" class="flex flex-col gap-3 p-4 bg-white dark:bg-slate-900 rounded-xl shadow-sm mb-4">
                    <div class="flex flex-wrap gap-3">
                        <input type="text" name="SearchTerm" class="flex-1 min-w-[200px] px-4 py-2 border border-slate-200 dark:border-slate-700 rounded-lg" value="@searchDto.SearchTerm" placeholder="البحث بالاسم..." />
                        <select name="CategoryId" class="px-4 py-2 border border-slate-200 dark:border-slate-700 rounded-lg">
                            <option value="">الكل</option>
                            <option value="1" selected="@(searchDto.CategoryId == 1)">سباكة</option>
                            <option value="2" selected="@(searchDto.CategoryId == 2)">كهرباء</option>
                            <option value="3" selected="@(searchDto.CategoryId == 3)">نجارة</option>
                            <option value="4" selected="@(searchDto.CategoryId == 4)">تكييف</option>
                            <option value="5" selected="@(searchDto.CategoryId == 5)">دهانات</option>
                        </select>
                        <select name="SortBy" class="px-4 py-2 border border-slate-200 dark:border-slate-700 rounded-lg">
                            <option value="">افتراضي</option>
                            <option value="PriceAsc" selected="@(searchDto.SortBy == "PriceAsc")">السعر: من الأقل للأعلى</option>
                            <option value="PriceDesc" selected="@(searchDto.SortBy == "PriceDesc")">السعر: من الأعلى للأقل</option>
                            <option value="Rating" selected="@(searchDto.SortBy == "Rating")">التقييم</option>
                        </select>
                        <button type="submit" class="px-6 py-2 bg-primary text-white rounded-lg font-bold hover:bg-primary/90">تصفية</button>
                    </div>
                </form>

                <div class="flex flex-col gap-4">
                    @foreach (var worker in Model.Items)
                    {
                    <div class="flex flex-col md:flex-row gap-4 p-5 bg-white dark:bg-slate-900 rounded-xl border border-slate-100 dark:border-slate-800 hover:border-primary/50 transition-colors shadow-sm">
                        <div class="relative size-24 shrink-0">
                            <div class="size-24 rounded-lg bg-primary/10 flex items-center justify-center">
                                <span class="material-symbols-outlined text-4xl text-primary">person</span>
                            </div>
                            <div class="absolute -bottom-1 -right-1 @(worker.Availability.ToString() == "Available" ? "bg-green-500" : "bg-slate-300") size-4 rounded-full border-2 border-white dark:border-slate-900"></div>
                        </div>
                        <div class="flex flex-col flex-1 gap-1">
                            <div class="flex justify-between items-start">
                                <div>
                                    <h3 class="font-bold text-lg">@worker.FullName</h3>
                                    <p class="text-slate-500 text-sm flex items-center gap-1"><span class="material-symbols-outlined text-sm">handyman</span> @worker.CategoryName</p>
                                </div>
                                <div class="text-left"><p class="text-primary font-bold text-lg">@worker.HourlyRate</p><p class="text-slate-400 text-xs">ج.م/ساعة</p></div>
                            </div>
                            <div class="flex items-center gap-3 mt-2">
                                <div class="flex items-center gap-1 bg-yellow-50 dark:bg-yellow-900/20 px-2 py-0.5 rounded text-yellow-700 text-sm font-bold"><span class="material-symbols-outlined text-sm">star</span> @worker.AverageRating.ToString("0.0")</div>
                                <span class="badge @(worker.IsVerified ? "bg-success" : "bg-secondary")">@(worker.IsVerified ? "موثق" : "غير موثق")</span>
                            </div>
                            <div class="mt-4 flex gap-3">
                                <a asp-controller="ServiceRequest" asp-action="Create" asp-route-workerId="@worker.Id" asp-route-customerId="101" class="flex-1 bg-primary text-white py-2.5 rounded-lg font-bold hover:bg-primary/90 transition-all text-center">اختيار الفني</a>
                                <a asp-controller="Customer" asp-action="Details" asp-route-id="@worker.Id" class="px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-lg font-bold hover:bg-slate-50 dark:hover:bg-slate-800 transition-all text-center">الملف الشخصي</a>
                            </div>
                        </div>
                    </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <div class="flex justify-center gap-2 mt-4">
                        @if (Model.HasPreviousPage)
                        {
                            <a asp-action="Index" asp-controller="Customer" asp-route-PageNumber="@(Model.PageNumber - 1)"
                               asp-route-SearchTerm="@searchDto.SearchTerm"
                               asp-route-CategoryId="@searchDto.CategoryId"
                               asp-route-SortBy="@searchDto.SortBy"
                               class="px-4 py-2 border border-slate-200 dark:border-slate-700 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800">السابق</a>
                        }
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <a asp-action="Index" asp-controller="Customer" asp-route-PageNumber="@i"
                               asp-route-SearchTerm="@searchDto.SearchTerm"
                               asp-route-CategoryId="@searchDto.CategoryId"
                               asp-route-SortBy="@searchDto.SortBy"
                               class="px-4 py-2 border @(i == Model.PageNumber ? "bg-primary text-white border-primary" : "border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800") rounded-lg">@i</a>
                        }
                        @if (Model.HasNextPage)
                        {
                            <a asp-action="Index" asp-controller="Customer" asp-route-PageNumber="@(Model.PageNumber + 1)"
                               asp-route-SearchTerm="@searchDto.SearchTerm"
                               asp-route-CategoryId="@searchDto.CategoryId"
                               asp-route-SortBy="@searchDto.SortBy"
                               class="px-4 py-2 border border-slate-200 dark:border-slate-700 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800">التالي</a>
                        }
                    </div>
                }
            </div>
        </main>
    </div>
</div>

