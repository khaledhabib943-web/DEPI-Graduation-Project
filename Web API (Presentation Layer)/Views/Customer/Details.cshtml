@model Application.DTOs.WorkerDto

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5 d-flex justify-content-center">
    <div class="card p-4 shadow" style="width: 400px;">

        <h3>@Model.FullName</h3>

        <p><strong>Category:</strong> @Model.CategoryName</p>
        <p><strong>Hourly Rate:</strong> @Model.HourlyRate EGP/hr</p>
        <p><strong>Bio:</strong> @Model.Bio</p>
        <p><strong>Rating:</strong> @Model.AverageRating</p>
        
        <div class="mt-3">
            <a href="/Customer" class="btn btn-secondary">Back</a>
            <a href="/ServiceRequest/Create?workerId=@Model.Id&customerId=101" class="btn btn-primary ms-2">Book</a>
        </div>
    </div>
</div>