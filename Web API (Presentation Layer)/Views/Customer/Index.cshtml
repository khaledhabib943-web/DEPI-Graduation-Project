@model Application.Wrappers.PagedResult<Application.DTOs.WorkerDto>
@{
    var searchDto = ViewData["SearchParameters"] as Application.DTOs.WorkerSearchDto ?? new Application.DTOs.WorkerSearchDto();
    var isEnglish = !ViewContext.RouteData.Values["action"]?.ToString().EndsWith("En") == true;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">
    <h2 class="mb-4">@(isEnglish ? "Find Professionals" : "البحث عن فنيين")</h2>

    <!-- Filter Form -->
    <form asp-action="Index" asp-controller="Customer" method="get" class="card p-4 mb-4">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">@(isEnglish ? "Search" : "بحث")</label>
                <input type="text" name="SearchTerm" class="form-control" value="@searchDto.SearchTerm" placeholder="@(isEnglish ? "Search by name..." : "البحث بالاسم...")" />
            </div>
            <div class="col-md-2">
                <label class="form-label">@(isEnglish ? "Category" : "التصنيف")</label>
                <select name="CategoryId" class="form-select">
                    <option value="">@(isEnglish ? "All" : "الكل")</option>
                    <option value="1" selected="@(searchDto.CategoryId == 1)">@(isEnglish ? "Plumbing" : "سباكة")</option>
                    <option value="2" selected="@(searchDto.CategoryId == 2)">@(isEnglish ? "Electrical" : "كهرباء")</option>
                    <option value="3" selected="@(searchDto.CategoryId == 3)">@(isEnglish ? "Carpentry" : "نجارة")</option>
                    <option value="4" selected="@(searchDto.CategoryId == 4)">@(isEnglish ? "HVAC" : "تكييف")</option>
                    <option value="5" selected="@(searchDto.CategoryId == 5)">@(isEnglish ? "Painting" : "دهانات")</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">@(isEnglish ? "Min Price" : "أقل سعر")</label>
                <input type="number" name="MinPrice" class="form-control" value="@searchDto.MinPrice" placeholder="0" />
            </div>
            <div class="col-md-2">
                <label class="form-label">@(isEnglish ? "Max Price" : "أعلى سعر")</label>
                <input type="number" name="MaxPrice" class="form-control" value="@searchDto.MaxPrice" placeholder="1000" />
            </div>
            <div class="col-md-2">
                <label class="form-label">@(isEnglish ? "Sort By" : "ترتيب حسب")</label>
                <select name="SortBy" class="form-select">
                    <option value="">@(isEnglish ? "Default" : "افتراضي")</option>
                    <option value="PriceAsc" selected="@(searchDto.SortBy == "PriceAsc")">@(isEnglish ? "Price: Low to High" : "السعر: من الأقل للأعلى")</option>
                    <option value="PriceDesc" selected="@(searchDto.SortBy == "PriceDesc")">@(isEnglish ? "Price: High to Low" : "السعر: من الأعلى للأقل")</option>
                    <option value="Rating" selected="@(searchDto.SortBy == "Rating")">@(isEnglish ? "Rating" : "التقييم")</option>
                </select>
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">@(isEnglish ? "Filter" : "تصفية")</button>
            </div>
        </div>
    </form>

    <!-- Results Count -->
    <p class="text-muted mb-3">@Model.TotalCount @(isEnglish ? "workers found" : "فني موجود")</p>

    <!-- Workers Grid -->
    <div class="row">
        @foreach (var worker in Model.Items)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                                <span class="material-symbols-outlined">person</span>
                            </div>
                            <div>
                                <h5 class="card-title mb-0">@worker.FullName</h5>
                                <p class="text-muted small mb-0">@worker.CategoryName</p>
                            </div>
                        </div>
                        <p class="card-text small">@worker.Bio</p>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="badge @(worker.IsVerified ? "bg-success" : "bg-secondary")">
                                @(worker.IsVerified ? (isEnglish ? "Verified" : "موثق") : (isEnglish ? "Unverified" : "غير موثق"))
                            </span>
                            <span class="text-primary fw-bold">@worker.HourlyRate @(isEnglish ? "EGP/hr" : "ج.م/ساعة")</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="badge @(worker.Availability.ToString() == "Available" ? "bg-success" : worker.Availability.ToString() == "Busy" ? "bg-warning" : "bg-secondary")">
                                @worker.Availability
                            </span>
                            <span class="text-warning">
                                <span class="material-symbols-outlined small">star</span>
                                @worker.AverageRating.ToString("0.0")
                            </span>
                        </div>
                        <div class="d-flex gap-2">
                            <a asp-controller="ServiceRequest" asp-action="Create" asp-route-workerId="@worker.Id" asp-route-customerId="101" class="btn btn-primary flex-grow-1">
                                @(isEnglish ? "Book Now" : "احجز الآن")
                            </a>
                            <a asp-controller="Favorite" asp-action="Add" asp-route-workerId="@worker.Id" asp-route-customerId="101" class="btn btn-outline-danger">
                                <span class="material-symbols-outlined">favorite</span>
                            </a>
                            <a asp-controller="Customer" asp-action="Details" asp-route-id="@worker.Id" class="btn btn-outline-secondary">
                                @(isEnglish ? "Profile" : "الملف")
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                @if (Model.HasPreviousPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-PageNumber="@(Model.PageNumber - 1)"
                           asp-route-SearchTerm="@searchDto.SearchTerm"
                           asp-route-CategoryId="@searchDto.CategoryId"
                           asp-route-MinPrice="@searchDto.MinPrice"
                           asp-route-MaxPrice="@searchDto.MaxPrice"
                           asp-route-SortBy="@searchDto.SortBy">@(isEnglish ? "Previous" : "السابق")</a>
                    </li>
                }
                else
                {
                    <li class="page-item disabled">
                        <span class="page-link">@(isEnglish ? "Previous" : "السابق")</span>
                    </li>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-PageNumber="@i"
                           asp-route-SearchTerm="@searchDto.SearchTerm"
                           asp-route-CategoryId="@searchDto.CategoryId"
                           asp-route-MinPrice="@searchDto.MinPrice"
                           asp-route-MaxPrice="@searchDto.MaxPrice"
                           asp-route-SortBy="@searchDto.SortBy">@i</a>
                    </li>
                }

                @if (Model.HasNextPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-PageNumber="@(Model.PageNumber + 1)"
                           asp-route-SearchTerm="@searchDto.SearchTerm"
                           asp-route-CategoryId="@searchDto.CategoryId"
                           asp-route-MinPrice="@searchDto.MinPrice"
                           asp-route-MaxPrice="@searchDto.MaxPrice"
                           asp-route-SortBy="@searchDto.SortBy">@(isEnglish ? "Next" : "التالي")</a>
                    </li>
                }
                else
                {
                    <li class="page-item disabled">
                        <span class="page-link">@(isEnglish ? "Next" : "التالي")</span>
                    </li>
                }
            </ul>
        </nav>
    }
</div>