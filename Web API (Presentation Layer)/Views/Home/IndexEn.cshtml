@model Application.DTOs.HomeDataDto
@* Landing Page Home – English (LTR) *@
@* Bundle: Public | Layout assumes _Layout loads TailwindCSS + main-theme.css *@

<div class="relative flex min-h-screen w-full flex-col overflow-x-hidden" dir="ltr">
    <div class="layout-container flex h-full grow flex-col">
        <header class="flex items-center justify-between whitespace-nowrap border-b border-primary/10 bg-white dark:bg-slate-900 px-6 md:px-20 py-3 sticky top-0 z-50 backdrop-blur-lg bg-white/90">
            <div class="flex items-center gap-4">
                <div class="bg-primary p-2 rounded-xl text-white"><span class="material-symbols-outlined">home_repair_service</span></div>
                <h1 class="text-xl font-extrabold tracking-tight">Salahly</h1>
            </div>
            <nav class="hidden md:flex items-center gap-8">
                <a class="text-slate-600 text-sm font-medium hover:text-primary transition-colors" asp-controller="Home" asp-action="Index">Home</a>
                <a class="text-slate-600 text-sm font-medium hover:text-primary transition-colors" asp-controller="Customer" asp-action="Index">Services</a>
                <a class="text-slate-600 text-sm font-medium hover:text-primary transition-colors" asp-controller="Complaint" asp-action="Index">Contact Us</a>
            </nav>
            <div class="flex items-center gap-3">
                <a class="text-primary text-sm font-bold hover:underline" asp-controller="Account" asp-action="Login">Login</a>
                <a class="bg-primary text-white px-5 py-2.5 rounded-lg font-bold text-sm hover:bg-primary/90 transition-colors shadow-lg shadow-primary/20" asp-controller="Account" asp-action="Register">Sign Up</a>
            </div>
        </header>
        <main>
            <section class="px-6 md:px-20 py-16 md:py-24 flex flex-col md:flex-row items-center gap-12">
                <div class="flex-1 flex flex-col gap-6">
                    <div class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-2 rounded-full text-sm font-bold w-fit"><span class="material-symbols-outlined text-base">verified</span> Verified & Reviewed Pros</div>
                    <h2 class="text-4xl md:text-6xl font-black leading-tight tracking-tight">Book a <span class="text-primary">Professional</span><br />Repair Technician</h2>
                    <p class="text-slate-500 text-lg max-w-lg">Salahly connects you with Egypt's top-rated, certified maintenance professionals. Plumbing, electrical, AC, and more.</p>
                    <div class="flex gap-4 mt-4">
                        <a class="bg-primary text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-primary/90 transition-all shadow-xl shadow-primary/20 flex items-center gap-2" asp-controller="Customer" asp-action="Index"><span class="material-symbols-outlined">search</span> Find a Pro</a>
                        <a class="border-2 border-slate-200 px-6 py-4 rounded-xl font-bold text-lg hover:border-primary hover:text-primary transition-colors" asp-controller="Home" asp-action="Index">How It Works</a>
                    </div>
                </div>
                <div class="flex-1 max-w-lg">
                    <div class="aspect-square rounded-2xl bg-slate-100 dark:bg-slate-800 overflow-hidden shadow-2xl flex items-center justify-center">
                        <span class="material-symbols-outlined text-9xl text-primary/30">home_repair_service</span>
                    </div>
                </div>
            </section>
            <section class="px-6 md:px-20 py-16 bg-white dark:bg-slate-900">
                <div class="text-center mb-12">
                    <h3 class="text-3xl font-bold mb-3">Our Services</h3>
                    <p class="text-slate-500 max-w-md mx-auto">Discover a wide range of certified home maintenance services.</p>
                </div>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    @foreach (var category in Model.Categories)
                    {
                    <a asp-controller="Customer" asp-action="Index" asp-route-CategoryId="@category.Id" class="group flex flex-col items-center gap-4 p-6 rounded-xl border border-slate-200 dark:border-slate-800 hover:border-primary hover:shadow-lg transition-all cursor-pointer">
                        <div class="size-16 rounded-2xl bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors"><span class="material-symbols-outlined text-3xl">handyman</span></div>
                        <h4 class="font-bold text-center">@category.Name</h4>
                    </a>
                    }
                </div>
            </section>

            <!-- Featured Workers Section -->
            <section class="px-6 md:px-20 py-16 bg-slate-50 dark:bg-slate-800">
                <div class="text-center mb-12">
                    <h3 class="text-3xl font-bold mb-3">Top Professionals</h3>
                    <p class="text-slate-500 max-w-md mx-auto">Certified professionals with high ratings</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    @foreach (var worker in Model.FeaturedWorkers)
                    {
                    <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
                        <div class="flex items-center gap-4 mb-4">
                            <div class="size-12 rounded-full bg-primary/10 flex items-center justify-center">
                                <span class="material-symbols-outlined text-primary">person</span>
                            </div>
                            <div>
                                <h4 class="font-bold">@worker.FullName</h4>
                                <p class="text-slate-500 text-sm">@worker.CategoryName</p>
                            </div>
                        </div>
                        <div class="flex justify-between items-center mb-3">
                            <span class="text-primary font-bold">@worker.HourlyRate EGP/hr</span>
                            <span class="text-yellow-600 flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm">star</span>
                                @worker.AverageRating.ToString("0.0")
                            </span>
                        </div>
                        <a asp-controller="ServiceRequest" asp-action="Create" asp-route-workerId="@worker.Id" asp-route-customerId="101" class="block w-full text-center bg-primary text-white py-2 rounded-lg font-bold hover:bg-primary/90 transition-colors">Book Now</a>
                    </div>
                    }
                </div>
            </section>

            <!-- Recent Reviews Section -->
            <section class="px-6 md:px-20 py-16 bg-white dark:bg-slate-900">
                <div class="text-center mb-12">
                    <h3 class="text-3xl font-bold mb-3">Customer Reviews</h3>
                    <p class="text-slate-500 max-w-md mx-auto">What our customers say about our services</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    @foreach (var review in Model.RecentReviews)
                    {
                    <div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-6">
                        <div class="flex items-center gap-1 mb-3">
                            @for (int i = 1; i <= review.Rating; i++)
                            {
                            <span class="material-symbols-outlined text-yellow-500 text-sm">star</span>
                            }
                        </div>
                        <p class="text-slate-600 dark:text-slate-300 mb-4">"@review.Comment"</p>
                        <p class="font-bold text-sm">- @review.CustomerName</p>
                    </div>
                    }
                </div>
            </section>
        </main>
        <footer class="bg-slate-900 text-white py-12 px-6 md:px-20">
            <div class="flex flex-col md:flex-row justify-between gap-8">
                <div><h4 class="font-bold text-xl mb-3">Salahly</h4><p class="text-slate-400 text-sm max-w-sm">Your trusted platform for home maintenance services in Egypt.</p></div>
                <div class="flex gap-12">
                    <div><h5 class="font-bold mb-3">Quick Links</h5><div class="flex flex-col gap-2 text-slate-400 text-sm"><a asp-controller="Home" asp-action="Index">Home</a><a asp-controller="Customer" asp-action="Index">Services</a><a asp-controller="Complaint" asp-action="Index">Contact</a></div></div>
                    <div><h5 class="font-bold mb-3">Legal</h5><div class="flex flex-col gap-2 text-slate-400 text-sm"><a href="#">Privacy Policy</a><a href="#">Terms of Service</a></div></div>
                </div>
            </div>
            <div class="border-t border-slate-800 mt-8 pt-8 text-center text-slate-500 text-sm">© 2024 Salahly. All rights reserved.</div>
        </footer>
    </div>
</div>

