@model FavoriteListViewModel
@{ ViewData["Title"] = "المفضلة"; Layout = "_LayoutArabic"; }

<div class="px-6 md:px-20 lg:px-40 py-8">
    <div class="max-w-[960px] mx-auto flex flex-col gap-8">
        <div><h1 class="text-3xl font-black">المفضلة</h1><p class="text-slate-500">الفنيون المحفوظون لديك</p></div>
        @if (Model.Favorites.Any())
        { <div class="grid grid-cols-1 md:grid-cols-2 gap-6">@foreach (var f in Model.Favorites)
            { <div class="bg-white dark:bg-slate-900 rounded-xl border p-5 flex items-center gap-4 hover:border-primary/50 shadow-sm"><div class="size-16 rounded-lg bg-primary/10 text-primary flex items-center justify-center shrink-0"><span class="material-symbols-outlined !text-2xl">person</span></div><div class="flex-1"><h3 class="font-bold text-lg">@f.WorkerName</h3><p class="text-sm text-slate-500">أضيف @f.AddedAt.ToString("dd MMM yyyy")</p></div><form asp-action="RemoveAr" method="post"><input type="hidden" name="workerId" value="@f.WorkerId" /><button class="size-10 rounded-lg bg-red-50 text-red-500 flex items-center justify-center hover:bg-red-100"><span class="material-symbols-outlined">heart_broken</span></button></form></div> }
        </div> }
        else { <div class="bg-white rounded-xl p-12 text-center border"><span class="material-symbols-outlined text-5xl text-slate-300 mb-4">favorite_border</span><p class="text-slate-500">لا توجد مفضلات. <a asp-controller="ServiceRequest" asp-action="SelectServiceAr" class="text-primary font-bold">تصفح الفنيين!</a></p></div> }
    </div>
</div>
