@model Setup2faViewModel
@{ ViewData["Title"] = "إعداد المصادقة الثنائية"; Layout = "_LayoutArabic"; }

<div class="px-6 md:px-20 lg:px-40 py-8">
    <div class="max-w-2xl mx-auto space-y-8">
        <!-- Header -->
        <div class="text-center">
            <div class="size-20 mx-auto flex items-center justify-center bg-primary/10 rounded-2xl mb-4">
                <span class="material-symbols-outlined !text-5xl text-primary">security</span>
            </div>
            <h1 class="text-3xl font-black mb-2">إعداد المصادقة الثنائية</h1>
            <p class="text-slate-500">أضف طبقة أمان إضافية لحسابك باستخدام تطبيق المصادقة.</p>
        </div>

        <!-- Step 1: Scan QR Code -->
        <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-100 dark:border-slate-800">
            <div class="flex items-center gap-3 mb-4">
                <div class="size-8 flex items-center justify-center bg-primary text-white rounded-full text-sm font-bold">١</div>
                <h3 class="text-lg font-bold">مسح رمز QR</h3>
            </div>
            <p class="text-slate-500 text-sm mb-6">
                افتح تطبيق المصادقة (Google Authenticator أو Microsoft Authenticator أو ما شابه) وامسح رمز QR هذا:
            </p>
            <div class="flex justify-center mb-6">
                <div id="qrcode" class="bg-white p-4 rounded-xl shadow-inner border border-slate-100"></div>
            </div>
            <details class="group">
                <summary class="text-sm font-semibold text-primary cursor-pointer flex items-center gap-1 hover:underline">
                    <span class="material-symbols-outlined text-sm">keyboard</span> لا يمكنك المسح؟ أدخل المفتاح يدوياً
                </summary>
                <div class="mt-3 p-4 bg-slate-50 dark:bg-slate-800 rounded-lg">
                    <p class="text-xs text-slate-500 mb-2">أدخل هذا المفتاح في تطبيق المصادقة:</p>
                    <code class="block text-center text-lg font-mono font-bold tracking-wider bg-white dark:bg-slate-700 px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-600 select-all" dir="ltr">@Model.SharedKey</code>
                </div>
            </details>
        </div>

        <!-- Step 2: Verify Code -->
        <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-100 dark:border-slate-800">
            <div class="flex items-center gap-3 mb-4">
                <div class="size-8 flex items-center justify-center bg-primary text-white rounded-full text-sm font-bold">٢</div>
                <h3 class="text-lg font-bold">تأكيد الرمز</h3>
            </div>
            <p class="text-slate-500 text-sm mb-6">أدخل الرمز المكون من 6 أرقام الظاهر في تطبيق المصادقة للتحقق من الإعداد:</p>
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="mb-4 p-3 rounded-lg bg-red-50 text-red-600 text-sm font-medium">@Model.ErrorMessage</div>
            }
            <form asp-action="SetupAr" method="post" class="space-y-6">
                <div class="space-y-2">
                    <label class="text-sm font-semibold">رمز التحقق</label>
                    <input asp-for="Code" class="form-input w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 h-14 text-center text-2xl font-mono tracking-[0.5em] focus:ring-2 focus:ring-primary" placeholder="000000" maxlength="6" autocomplete="one-time-code" inputmode="numeric" dir="ltr" />
                    <span asp-validation-for="Code" class="text-red-500 text-xs"></span>
                </div>
                <div class="flex gap-4">
                    <button type="submit" class="flex-1 h-12 bg-primary text-white font-bold rounded-lg shadow-lg shadow-primary/20 flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-[20px]">check_circle</span>
                        تفعيل المصادقة الثنائية
                    </button>
                    <a asp-controller="Profile" asp-action="IndexAr" class="h-12 px-6 bg-slate-100 dark:bg-slate-800 text-slate-600 font-bold rounded-lg flex items-center justify-center hover:bg-slate-200 transition-colors">
                        إلغاء
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
    <script>
        new QRCode(document.getElementById("qrcode"), {
            text: "@Html.Raw(Model.AuthenticatorUri)",
            width: 200,
            height: 200,
            colorDark: "#0f172a",
            colorLight: "#ffffff",
            correctLevel: QRCode.CorrectLevel.M
        });
    </script>
}
