@model DashboardViewModel
@{ ViewData["Title"] = "Dashboard"; }

<div class="px-6 md:px-20 lg:px-40 py-8">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
        <!-- Welcome -->
        <div class="flex flex-col gap-2">
            <h1 class="text-slate-900 dark:text-slate-100 text-3xl font-black tracking-tight">Welcome back, @Model.CustomerName 👋</h1>
            <p class="text-slate-500 dark:text-slate-400 text-lg">Here's what's happening with your home services.</p>
        </div>
        <!-- Stats Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-center gap-4">
                    <div class="size-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center"><span class="material-symbols-outlined">pending_actions</span></div>
                    <div><p class="text-2xl font-black text-slate-900 dark:text-slate-100">@Model.ActiveRequestsCount</p><p class="text-sm text-slate-500">Active Requests</p></div>
                </div>
            </div>
            <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-center gap-4">
                    <div class="size-12 rounded-xl bg-emerald-500/10 text-emerald-500 flex items-center justify-center"><span class="material-symbols-outlined">task_alt</span></div>
                    <div><p class="text-2xl font-black text-slate-900 dark:text-slate-100">@Model.CompletedRequestsCount</p><p class="text-sm text-slate-500">Completed</p></div>
                </div>
            </div>
            <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-center gap-4">
                    <div class="size-12 rounded-xl bg-rose-500/10 text-rose-500 flex items-center justify-center"><span class="material-symbols-outlined">favorite</span></div>
                    <div><p class="text-2xl font-black text-slate-900 dark:text-slate-100">@Model.FavoritesCount</p><p class="text-sm text-slate-500">Favorites</p></div>
                </div>
            </div>
            <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-center gap-4">
                    <div class="size-12 rounded-xl bg-amber-500/10 text-amber-500 flex items-center justify-center"><span class="material-symbols-outlined">notifications</span></div>
                    <div><p class="text-2xl font-black text-slate-900 dark:text-slate-100">@Model.UnreadNotifications</p><p class="text-sm text-slate-500">Unread Alerts</p></div>
                </div>
            </div>
        </div>
        <!-- Quick Actions -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <a asp-controller="ServiceRequest" asp-action="SelectService" class="group flex items-center gap-4 bg-primary text-white rounded-2xl p-6 shadow-lg shadow-primary/20 hover:shadow-xl transition-all">
                <div class="size-12 rounded-xl bg-white/20 flex items-center justify-center"><span class="material-symbols-outlined !text-2xl">add_circle</span></div>
                <div><p class="font-bold text-lg">Book a Service</p><p class="text-white/70 text-sm">Get help from certified pros</p></div>
            </a>
            <a asp-controller="Notification" asp-action="Index" class="group flex items-center gap-4 bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-800 hover:border-primary/50 transition-all">
                <div class="size-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center"><span class="material-symbols-outlined !text-2xl">notifications</span></div>
                <div><p class="font-bold text-lg text-slate-900 dark:text-slate-100">Notifications</p><p class="text-slate-500 text-sm">@Model.UnreadNotifications unread</p></div>
            </a>
            <a asp-controller="Complaint" asp-action="Index" class="group flex items-center gap-4 bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-800 hover:border-primary/50 transition-all">
                <div class="size-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center"><span class="material-symbols-outlined !text-2xl">support_agent</span></div>
                <div><p class="font-bold text-lg text-slate-900 dark:text-slate-100">Complaints</p><p class="text-slate-500 text-sm">View & submit</p></div>
            </a>
        </div>
        <!-- Recent Requests -->
        <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">
            <div class="p-6 border-b border-slate-200 dark:border-slate-800"><h2 class="text-xl font-bold text-slate-900 dark:text-slate-100">Recent Requests</h2></div>
            @if (Model.RecentRequests.Any())
            {
                <div class="divide-y divide-slate-100 dark:divide-slate-800">
                    @foreach (var req in Model.RecentRequests)
                    {
                        <div class="p-6 flex items-center justify-between hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                            <div class="flex items-center gap-4">
                                <div class="size-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center"><span class="material-symbols-outlined">handyman</span></div>
                                <div>
                                    <p class="font-bold text-slate-900 dark:text-slate-100">Request #@req.RequestId</p>
                                    <p class="text-sm text-slate-500">@req.ScheduledDate.ToString("MMM dd, yyyy")</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-4">
                                <span class="px-3 py-1 rounded-full text-xs font-semibold @(req.Status == FinalProject.Domain.Enums.RequestStatus.Completed ? "bg-emerald-100 text-emerald-700" : req.Status == FinalProject.Domain.Enums.RequestStatus.Pending ? "bg-amber-100 text-amber-700" : "bg-blue-100 text-blue-700")">@req.Status</span>
                                <a asp-controller="ServiceRequest" asp-action="TrackRequest" asp-route-requestId="@req.RequestId" class="text-primary font-bold text-sm hover:underline">Track</a>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="p-12 text-center">
                    <span class="material-symbols-outlined text-5xl text-slate-300 mb-4">inbox</span>
                    <p class="text-slate-500">No requests yet. <a asp-controller="ServiceRequest" asp-action="SelectService" class="text-primary font-bold">Book your first service!</a></p>
                </div>
            }
        </div>
    </div>
</div>
