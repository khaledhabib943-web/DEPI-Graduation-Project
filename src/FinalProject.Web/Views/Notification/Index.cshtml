@model NotificationListViewModel
@{ ViewData["Title"] = "Notifications"; }

<div class="px-6 md:px-20 lg:px-40 py-8">
    <div class="max-w-[960px] mx-auto flex flex-col gap-6">
        <div class="flex items-center justify-between">
            <div><h1 class="text-3xl font-black">Notifications</h1><p class="text-slate-500 text-sm">@Model.UnreadCount unread notifications</p></div>
        </div>
        <div class="space-y-4">
            @if (Model.Notifications.Any())
            {
                @foreach (var n in Model.Notifications)
                {
                    <div class="flex flex-col sm:flex-row gap-4 bg-white dark:bg-slate-900 p-5 rounded-xl border-l-4 @(n.IsRead ? "border-slate-200 opacity-80" : "border-primary") shadow-sm hover:shadow-md transition-shadow">
                        <div class="flex items-start gap-4 flex-1">
                            <div class="flex items-center justify-center rounded-xl @(n.IsRead ? "bg-slate-100 text-slate-400" : "bg-primary/10 text-primary") shrink-0 size-14">
                                <span class="material-symbols-outlined text-3xl">@(n.Type == FinalProject.Domain.Enums.NotificationType.RequestAccepted ? "check_circle" : n.Type == FinalProject.Domain.Enums.NotificationType.ServiceCompleted ? "task_alt" : "notifications")</span>
                            </div>
                            <div class="flex flex-col gap-1">
                                <div class="flex items-center gap-2">
                                    <p class="text-base font-bold">@n.Title</p>
                                    @if (!n.IsRead) { <span class="inline-block size-2 bg-primary rounded-full"></span> }
                                </div>
                                <p class="text-sm text-slate-600 dark:text-slate-400">@n.Message</p>
                                <span class="text-xs text-slate-400 flex items-center gap-1 mt-1"><span class="material-symbols-outlined text-sm">schedule</span> @n.CreatedAt.ToString("MMM dd, h:mm tt")</span>
                            </div>
                        </div>
                        @if (!n.IsRead)
                        {
                            <form asp-action="MarkAsRead" method="post" class="flex items-center">
                                <input type="hidden" name="id" value="@n.NotificationId" />
                                <button type="submit" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 text-sm font-bold rounded-lg hover:bg-primary hover:text-white transition-all">Mark Read</button>
                            </form>
                        }
                    </div>
                }
            }
            else
            {
                <div class="bg-white dark:bg-slate-900 rounded-xl p-12 text-center border"><span class="material-symbols-outlined text-5xl text-slate-300 mb-4">notifications_off</span><p class="text-slate-500">No notifications yet.</p></div>
            }
        </div>
    </div>
</div>
