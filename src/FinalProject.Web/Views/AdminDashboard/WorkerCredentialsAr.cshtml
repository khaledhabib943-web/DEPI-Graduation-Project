@model FinalProject.Web.ViewModels.AdminDashboardViewModel
@{ ViewData["Title"] = "مراجعة وثائق عمال الصيانة"; Layout = "_LayoutArabic"; }

<div class="px-6 md:px-20 lg:px-40 py-8">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
        
        <!-- Header -->
        <div class="flex items-center gap-4">
            <a asp-controller="AdminDashboard" asp-action="IndexAr" class="size-10 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 flex items-center justify-center hover:bg-primary/10 hover:text-primary transition-colors">
                <span class="material-symbols-outlined">arrow_forward</span>
            </a>
            <div>
                <h1 class="text-slate-900 dark:text-slate-100 text-3xl font-black tracking-tight">وثائق عمال الصيانة</h1>
                <p class="text-slate-500 dark:text-slate-400 text-sm">مراجعة وثائق هوية عمال الصيانة المسجلين حديثاً وقبولهم أو رفضهم.</p>
            </div>
        </div>

        @if (TempData["SuccessMessageAr"] != null)
        {
            <div class="p-4 rounded-xl bg-emerald-500/10 text-emerald-500 border border-emerald-500/20 flex items-center gap-3">
                <span class="material-symbols-outlined">check_circle</span>
                <span>@TempData["SuccessMessageAr"]</span>
            </div>
        }
        @if (TempData["ErrorMessageAr"] != null)
        {
            <div class="p-4 rounded-xl bg-red-500/10 text-red-500 border border-red-500/20 flex items-center gap-3">
                <span class="material-symbols-outlined">error</span>
                <span>@TempData["ErrorMessageAr"]</span>
            </div>
        }

        <!-- Pending Workers Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            @if (Model.PendingWorkers.Any())
            {
                @foreach (var w in Model.PendingWorkers)
                {
                    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 shadow-sm flex flex-col gap-6 text-right">
                        
                        <!-- Basic Info header -->
                        <div class="flex items-start gap-4">
                            @if (!string.IsNullOrEmpty(w.ProfilePicture))
                            {
                                <img src="@w.ProfilePicture" class="size-16 rounded-2xl object-cover" />
                            }
                            else
                            {
                                <div class="size-16 rounded-2xl bg-indigo-50 dark:bg-indigo-950/40 text-indigo-500 flex items-center justify-center font-black text-xl">
                                    @((w.FullName.Length >= 2) ? w.FullName.Substring(0, 2).ToUpper() : "W")
                                </div>
                            }
                            <div class="flex-1">
                                <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100">@w.FullName</h3>
                                <p class="text-xs text-slate-500">انضم في تاريخ: @w.CreatedAt.ToString("yyyy/MM/dd")</p>
                                <div class="flex flex-wrap gap-2 mt-2 justify-start">
                                    <span class="px-2.5 py-0.5 rounded-lg text-xs font-semibold bg-indigo-50 dark:bg-indigo-900/20 text-indigo-600 dark:text-indigo-400">@w.CategoryName</span>
                                    <span class="px-2.5 py-0.5 rounded-lg text-xs font-semibold bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400">العمر: @w.Age عاماً</span>
                                </div>
                            </div>
                        </div>

                        <!-- Info details -->
                        <div class="grid grid-cols-2 gap-4 text-xs bg-slate-50 dark:bg-slate-800/40 p-4 rounded-xl border border-slate-100 dark:border-slate-800/80">
                            <div>
                                <p class="text-slate-400 uppercase font-semibold">الرقم القومي</p>
                                <p class="font-bold text-slate-800 dark:text-slate-200 mt-0.5">@w.NationalId</p>
                            </div>
                            <div>
                                <p class="text-slate-400 uppercase font-semibold">رقم الهاتف</p>
                                <p class="font-bold text-slate-800 dark:text-slate-200 mt-0.5">@w.PhoneNumber</p>
                            </div>
                            <div class="col-span-2">
                                <p class="text-slate-400 uppercase font-semibold">البريد الإلكتروني</p>
                                <p class="font-bold text-slate-800 dark:text-slate-200 mt-0.5">@w.Email</p>
                            </div>
                        </div>

                        <!-- ID Pictures (Vetting Docs) -->
                        <div>
                            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">وثائق الهوية الوطنية</p>
                            <div class="grid grid-cols-2 gap-4">
                                <div class="flex flex-col gap-1.5 text-center">
                                    <span class="text-xs text-slate-500">وجه بطاقة الرقم القومي</span>
                                    <div class="relative group cursor-zoom-in rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden h-32 bg-slate-100 dark:bg-slate-900 flex items-center justify-center" onclick="zoomImage('@w.IdFrontImage', 'وجه البطاقة - @w.FullName')">
                                        @if (!string.IsNullOrEmpty(w.IdFrontImage))
                                        {
                                            <img src="@w.IdFrontImage" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
                                            <div class="absolute inset-0 bg-slate-900/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                                <span class="material-symbols-outlined text-white text-2xl">zoom_in</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined text-slate-300 text-3xl">image</span>
                                        }
                                    </div>
                                </div>
                                <div class="flex flex-col gap-1.5 text-center">
                                    <span class="text-xs text-slate-500">ظهر بطاقة الرقم القومي</span>
                                    <div class="relative group cursor-zoom-in rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden h-32 bg-slate-100 dark:bg-slate-900 flex items-center justify-center" onclick="zoomImage('@w.IdBackImage', 'ظهر البطاقة - @w.FullName')">
                                        @if (!string.IsNullOrEmpty(w.IdBackImage))
                                        {
                                            <img src="@w.IdBackImage" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
                                            <div class="absolute inset-0 bg-slate-900/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                                <span class="material-symbols-outlined text-white text-2xl">zoom_in</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined text-slate-300 text-3xl">image</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="flex items-center gap-3 border-t border-slate-100 dark:border-slate-800 pt-4 mt-2">
                            <button type="button" onclick="confirmReject('@w.UserId', '@w.FullName')" class="flex-1 py-2.5 rounded-xl border border-red-500/20 text-red-500 hover:bg-red-500/5 font-bold text-sm transition-colors text-center">
                                رفض العامل وحذفه
                            </button>
                            <form method="post" asp-action="ApproveWorker" class="flex-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="workerId" value="@w.UserId" />
                                <input type="hidden" name="redirectUrl" value="/AdminDashboard/WorkerCredentialsAr" />
                                <button type="submit" class="w-full py-2.5 rounded-xl bg-emerald-500 hover:bg-emerald-600 text-white font-bold text-sm transition-colors text-center shadow-lg shadow-emerald-500/10">
                                    قبول وتنشيط العامل
                                </button>
                            </form>
                        </div>

                    </div>
                }
            }
            else
            {
                <div class="col-span-2 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-16 text-center">
                    <span class="material-symbols-outlined text-6xl text-slate-300 mb-4">verified</span>
                    <h3 class="text-xl font-bold text-slate-600 dark:text-slate-400 mb-1">لا يوجد عمال في الانتظار</h3>
                    <p class="text-slate-400">جميع عمال الصيانة المسجلين قد تم التحقق من هوياتهم وقبولهم.</p>
                </div>
            }
        </div>

    </div>
</div>

<!-- Image Lightbox Modal -->
<div id="lightboxModal" class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-slate-900/90 hidden" onclick="closeLightbox()">
    <button class="absolute top-6 left-6 text-white hover:text-slate-300">
        <span class="material-symbols-outlined !text-4xl">close</span>
    </button>
    <div class="max-w-[90%] max-h-[80vh] flex items-center justify-center" onclick="event.stopPropagation()">
        <img id="lightboxImage" src="" class="rounded-2xl max-w-full max-h-[75vh] object-contain shadow-2xl" />
    </div>
    <h4 id="lightboxCaption" class="text-white text-lg font-bold mt-4 font-display">عنوان الوثيقة</h4>
</div>

<!-- Reject Confirmation Modal -->
<div id="rejectModal" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/60 backdrop-blur-sm hidden text-right">
    <div class="bg-white dark:bg-slate-900 rounded-3xl w-full max-w-md p-8 border border-slate-200 dark:border-slate-800 shadow-2xl m-4 animate-in fade-in zoom-in-95 duration-200">
        <div class="flex items-center gap-4 text-red-500 mb-4">
            <span class="material-symbols-outlined !text-4xl">warning</span>
            <h3 class="text-2xl font-black tracking-tight">رفض وثائق العامل</h3>
        </div>
        <p class="text-slate-500 dark:text-slate-400 text-sm mb-6 leading-relaxed">هل أنت متأكد من رغبتك في رفض وثائق <strong id="rejectWorkerName" class="text-slate-900 dark:text-slate-100">العامل</strong>؟ سيؤدي ذلك إلى رفض توثيق حسابه وحذف حسابه نهائياً من النظام.</p>
        <form id="rejectForm" method="post" asp-action="RejectWorker">
            @Html.AntiForgeryToken()
            <input type="hidden" id="rejectWorkerId" name="workerId" />
            <input type="hidden" name="redirectUrl" value="/AdminDashboard/WorkerCredentialsAr" />
            <div class="flex justify-end gap-3">
                <button type="button" onclick="closeRejectModal()" class="px-5 py-2.5 rounded-xl border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 font-bold hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">إلغاء</button>
                <button type="submit" class="px-5 py-2.5 rounded-xl bg-red-500 text-white font-bold hover:bg-red-600 transition-colors">رفض وحذف الحساب</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function zoomImage(src, caption) {
            if (!src) return;
            document.getElementById('lightboxImage').src = src;
            document.getElementById('lightboxCaption').innerText = caption;
            document.getElementById('lightboxModal').classList.remove('hidden');
        }
        function closeLightbox() {
            document.getElementById('lightboxModal').classList.add('hidden');
        }
        function confirmReject(id, name) {
            document.getElementById('rejectWorkerId').value = id;
            document.getElementById('rejectWorkerName').innerText = name;
            document.getElementById('rejectModal').classList.remove('hidden');
        }
        function closeRejectModal() {
            document.getElementById('rejectModal').classList.add('hidden');
        }
    </script>
}
