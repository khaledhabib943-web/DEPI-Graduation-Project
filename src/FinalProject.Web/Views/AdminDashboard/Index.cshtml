@model FinalProject.Web.ViewModels.AdminDashboardViewModel
@{ ViewData["Title"] = "Admin Dashboard"; }

<div class="px-6 md:px-20 lg:px-40 py-8">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
        <!-- Welcome / Alerts -->
        <div class="flex flex-col gap-2">
            <h1 class="text-slate-900 dark:text-slate-100 text-3xl font-black tracking-tight">Admin Control Center 🛡️</h1>
            <p class="text-slate-500 dark:text-slate-400 text-lg">Manage platform users, verify credentials, and resolve customer complaints.</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="p-4 rounded-xl bg-emerald-500/10 text-emerald-500 border border-emerald-500/20 flex items-center gap-3">
                <span class="material-symbols-outlined">check_circle</span>
                <span>@TempData["SuccessMessage"]</span>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="p-4 rounded-xl bg-red-500/10 text-red-500 border border-red-500/20 flex items-center gap-3">
                <span class="material-symbols-outlined">error</span>
                <span>@TempData["ErrorMessage"]</span>
            </div>
        }

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-center gap-4">
                    <div class="size-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center">
                        <span class="material-symbols-outlined">group</span>
                    </div>
                    <div>
                        <p class="text-2xl font-black text-slate-900 dark:text-slate-100">@Model.TotalCustomers</p>
                        <p class="text-sm text-slate-500">Total Customers</p>
                    </div>
                </div>
            </div>
            <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-center gap-4">
                    <div class="size-12 rounded-xl bg-indigo-500/10 text-indigo-500 flex items-center justify-center">
                        <span class="material-symbols-outlined">engineering</span>
                    </div>
                    <div>
                        <p class="text-2xl font-black text-slate-900 dark:text-slate-100">@Model.TotalWorkers</p>
                        <p class="text-sm text-slate-500">Total Workers</p>
                    </div>
                </div>
            </div>
            <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-center gap-4">
                    <div class="size-12 rounded-xl bg-amber-500/10 text-amber-500 flex items-center justify-center">
                        <span class="material-symbols-outlined">report</span>
                    </div>
                    <div>
                        <p class="text-2xl font-black text-slate-900 dark:text-slate-100">@Model.PendingComplaintsCount</p>
                        <p class="text-sm text-slate-500">Pending Complaints</p>
                    </div>
                </div>
            </div>
            <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-center gap-4">
                    <div class="size-12 rounded-xl bg-rose-500/10 text-rose-500 flex items-center justify-center">
                        <span class="material-symbols-outlined">badge</span>
                    </div>
                    <div>
                        <p class="text-2xl font-black text-slate-900 dark:text-slate-100">@Model.PendingWorkersCount</p>
                        <p class="text-sm text-slate-500">Unverified Workers</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Sections Cards -->
        <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100 mt-2">Management Sections</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <a asp-controller="AdminDashboard" asp-action="Users" class="group bg-white dark:bg-slate-900 rounded-2xl p-8 border border-slate-200 dark:border-slate-800 hover:border-primary/50 hover:shadow-lg transition-all flex flex-col justify-between h-56">
                <div>
                    <div class="size-14 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined !text-3xl">people</span>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2">Users Management</h3>
                    <p class="text-slate-500 dark:text-slate-400 text-sm">Edit, delete, suspend, and view customers or workers.</p>
                </div>
                <div class="flex items-center text-primary font-bold text-sm mt-4 gap-1 group-hover:gap-2 transition-all">
                    <span>Manage Users</span>
                    <span class="material-symbols-outlined !text-sm">arrow_forward</span>
                </div>
            </a>

            <a asp-controller="AdminDashboard" asp-action="Complaints" class="group bg-white dark:bg-slate-900 rounded-2xl p-8 border border-slate-200 dark:border-slate-800 hover:border-amber-500/50 hover:shadow-lg transition-all flex flex-col justify-between h-56">
                <div>
                    <div class="size-14 rounded-2xl bg-amber-500/10 text-amber-500 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined !text-3xl">report</span>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2">Customer Complaints</h3>
                    <p class="text-slate-500 dark:text-slate-400 text-sm">Access, review, reply, and dismiss customer complaints.</p>
                </div>
                <div class="flex items-center text-amber-500 font-bold text-sm mt-4 gap-1 group-hover:gap-2 transition-all">
                    <span>Manage Complaints</span>
                    <span class="material-symbols-outlined !text-sm">arrow_forward</span>
                </div>
            </a>

            <a asp-controller="AdminDashboard" asp-action="WorkerCredentials" class="group bg-white dark:bg-slate-900 rounded-2xl p-8 border border-slate-200 dark:border-slate-800 hover:border-rose-500/50 hover:shadow-lg transition-all flex flex-col justify-between h-56">
                <div>
                    <div class="size-14 rounded-2xl bg-rose-500/10 text-rose-500 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined !text-3xl">badge</span>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2">Worker Vetting</h3>
                    <p class="text-slate-500 dark:text-slate-400 text-sm">Scan, accept, and reject worker signup credentials.</p>
                </div>
                <div class="flex items-center text-rose-500 font-bold text-sm mt-4 gap-1 group-hover:gap-2 transition-all">
                    <span>Verify Credentials</span>
                    <span class="material-symbols-outlined !text-sm">arrow_forward</span>
                </div>
            </a>

            <a asp-controller="AdminDashboard" asp-action="ServiceRequests" class="group bg-white dark:bg-slate-900 rounded-2xl p-8 border border-slate-200 dark:border-slate-800 hover:border-emerald-500/50 hover:shadow-lg transition-all flex flex-col justify-between h-56">
                <div>
                    <div class="size-14 rounded-2xl bg-emerald-500/10 text-emerald-500 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined !text-3xl">receipt_long</span>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2">Service Requests</h3>
                    <p class="text-slate-500 dark:text-slate-400 text-sm">View all requests with ratings, prices, and status timeline.</p>
                </div>
                <div class="flex items-center text-emerald-500 font-bold text-sm mt-4 gap-1 group-hover:gap-2 transition-all">
                    <span>View Requests</span>
                    <span class="material-symbols-outlined !text-sm">arrow_forward</span>
                </div>
            </a>
        </div>
    </div>
</div>
