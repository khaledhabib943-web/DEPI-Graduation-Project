@model ProfileViewModel
@inject Microsoft.AspNetCore.Identity.UserManager<FinalProject.Domain.Entities.User> UserManager
@{
    ViewData["Title"] = "الملف الشخصي"; Layout = "_LayoutArabic";
    var user = await UserManager.GetUserAsync(User);
    var is2faEnabled = user != null && await UserManager.GetTwoFactorEnabledAsync(user);
}

<div class="px-6 md:px-20 lg:px-40 py-8">
    <div class="max-w-3xl mx-auto">
        <div class="flex flex-col items-center mb-10">
            <div class="relative group">
                @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                {
                    <img src="@Model.ProfilePicture" class="size-32 rounded-full object-cover border-4 border-white shadow-xl" id="profileImagePreview" />
                }
                else
                {
                    <div class="size-32 rounded-full bg-primary text-white flex items-center justify-center text-4xl font-bold border-4 border-white shadow-xl" id="profileInitialsPreview">
                        @(Model.FullName.Length >= 2 ? Model.FullName.Substring(0, 2).ToUpper() : "U")
                    </div>
                }
            </div>
            <h2 class="text-2xl font-bold mt-4">الملف الشخصي</h2>
        </div>

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="mb-6 p-3 rounded-lg bg-emerald-50 text-emerald-600 text-sm font-medium flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">check_circle</span> @Model.SuccessMessage
            </div>
        }

        <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-100 dark:border-slate-800">
            <h3 class="text-lg font-bold mb-6 border-r-4 border-primary pr-3">البيانات الشخصية</h3>
            <form asp-action="IndexAr" method="post" enctype="multipart/form-data" class="space-y-5">
                @Html.AntiForgeryToken()

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <!-- الاسم بالكامل -->
                    <div class="flex flex-col gap-1">
                        <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">
                            الاسم بالكامل <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="FullName"
                               class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 h-12 px-4 focus:border-primary focus:ring-primary text-sm"
                               placeholder="مثال: أحمد محمد" />
                        <span asp-validation-for="FullName" class="text-red-500 text-xs font-medium"></span>
                        <p class="text-xs text-slate-400 mt-0.5">من 3 إلى 100 حرف · الحروف والمسافات والشرطات والنقاط فقط</p>
                    </div>

                    <!-- البريد الإلكتروني -->
                    <div class="flex flex-col gap-1">
                        <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">
                            البريد الإلكتروني <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="Email" type="email"
                               class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 h-12 px-4 focus:border-primary focus:ring-primary text-sm"
                               placeholder="example@email.com" />
                        <span asp-validation-for="Email" class="text-red-500 text-xs font-medium"></span>
                        <p class="text-xs text-slate-400 mt-0.5">يجب أن يكون بريداً صحيحاً · 150 حرفاً كحد أقصى</p>
                    </div>

                    <!-- رقم الهاتف -->
                    <div class="flex flex-col gap-1">
                        <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">
                            رقم الهاتف <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="PhoneNumber" type="tel"
                               class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 h-12 px-4 focus:border-primary focus:ring-primary text-sm"
                               placeholder="01012345678" maxlength="11" />
                        <span asp-validation-for="PhoneNumber" class="text-red-500 text-xs font-medium"></span>
                        <p class="text-xs text-slate-400 mt-0.5">أرقام مصرية فقط: يبدأ بـ 010 أو 011 أو 012 أو 015 · 11 رقماً بالضبط</p>
                    </div>

                    <!-- العمر -->
                    <div class="flex flex-col gap-1">
                        <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">
                            العمر <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="Age" type="number" min="18" max="100"
                               class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 h-12 px-4 focus:border-primary focus:ring-primary text-sm"
                               placeholder="مثال: 28" />
                        <span asp-validation-for="Age" class="text-red-500 text-xs font-medium"></span>
                        <p class="text-xs text-slate-400 mt-0.5">يجب أن يكون بين 18 و 100</p>
                    </div>
                </div>

                <!-- العنوان -->
                <div class="flex flex-col gap-1">
                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">العنوان التفصيلي</label>
                    <textarea asp-for="Address" rows="3"
                              class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-4 py-3 focus:border-primary focus:ring-primary text-sm resize-none"
                              placeholder="عنوانك الكامل (اختياري)"></textarea>
                    <span asp-validation-for="Address" class="text-red-500 text-xs font-medium"></span>
                    <p class="text-xs text-slate-400 mt-0.5">اختياري · 300 حرف كحد أقصى</p>
                </div>

                <!-- الصورة الشخصية -->
                <div class="flex flex-col gap-1">
                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">تغيير الصورة الشخصية</label>
                    <input asp-for="ProfilePictureFile" type="file" accept="image/*"
                           class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-4 py-2 text-sm focus:border-primary focus:ring-primary" />
                    <span asp-validation-for="ProfilePictureFile" class="text-red-500 text-xs font-medium"></span>
                    <p class="text-xs text-slate-400 mt-0.5">اختياري · الصيغ المقبولة: JPG, PNG, WebP</p>
                </div>

                @if (Model.Role == FinalProject.Domain.Enums.UserRole.Worker)
                {
                    <div class="border-t border-slate-100 dark:border-slate-800 pt-5 mt-2">
                        <h3 class="text-lg font-bold mb-5 border-r-4 border-primary pr-3">البيانات المهنية</h3>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <!-- التخصص -->
                        <div class="flex flex-col gap-1">
                            <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">
                                التخصص / القسم <span class="text-red-500">*</span>
                            </label>
                            <select asp-for="CategoryId"
                                    class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 h-12 px-4 focus:border-primary focus:ring-primary text-sm"
                                    asp-items="@(new SelectList(ViewBag.Categories, "CategoryId", "Name"))">
                                <option value="">-- اختر التخصص --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-red-500 text-xs font-medium"></span>
                        </div>

                        <!-- سعر الخدمة -->
                        <div class="flex flex-col gap-1">
                            <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">
                                سعر الخدمة لكل زيارة (جنيه) <span class="text-red-500">*</span>
                            </label>
                            <input asp-for="ServicePrice" type="number" step="0.01" min="1" max="100000"
                                   class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 h-12 px-4 focus:border-primary focus:ring-primary text-sm"
                                   placeholder="مثال: 250" />
                            <span asp-validation-for="ServicePrice" class="text-red-500 text-xs font-medium"></span>
                            <p class="text-xs text-slate-400 mt-0.5">يجب أن يكون بين 1 و 100,000 جنيه</p>
                        </div>

                        <!-- ملف الأعمال -->
                        <div class="flex flex-col gap-1 md:col-span-2">
                            <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">
                                ملف الأعمال
                                @if (!string.IsNullOrEmpty(Model.Portfolio))
                                {
                                    <span class="mr-2 text-xs text-slate-500 font-normal">(الحالي: @System.IO.Path.GetFileName(Model.Portfolio))</span>
                                }
                            </label>
                            @if (!string.IsNullOrEmpty(Model.Portfolio))
                            {
                                <a href="@Model.Portfolio" target="_blank" class="text-xs text-primary font-bold hover:underline mb-1 flex items-center gap-1 w-fit">
                                    <span class="material-symbols-outlined !text-sm">download</span> تحميل ملف الأعمال الحالي
                                </a>
                            }
                            <input asp-for="PortfolioFile" type="file"
                                   class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-4 py-2 text-sm focus:border-primary focus:ring-primary" />
                            <span asp-validation-for="PortfolioFile" class="text-red-500 text-xs font-medium"></span>
                            <p class="text-xs text-slate-400 mt-0.5">اختياري · ارفع ملف PDF أو صورة تعرض أعمالك السابقة</p>
                        </div>
                    </div>
                }

                <!-- ملخص الأخطاء -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="p-3 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-600 dark:text-red-400 text-sm">
                        <div class="flex items-center gap-2 font-semibold mb-1">
                            <span class="material-symbols-outlined !text-base">error</span> يرجى تصحيح الأخطاء أدناه قبل الحفظ.
                        </div>
                        <div asp-validation-summary="ModelOnly" class="text-xs space-y-0.5 mr-6"></div>
                    </div>
                }

                <div class="pt-2 flex gap-4">
                    <button type="submit" class="bg-primary text-white px-8 py-3 rounded-xl font-bold hover:bg-primary/90 shadow-lg shadow-primary/30 flex-1">
                        حفظ التعديلات
                    </button>
                    @if (Model.Role == FinalProject.Domain.Enums.UserRole.Worker)
                    {
                        <a asp-controller="WorkerDashboard" asp-action="IndexAr" class="bg-slate-100 dark:bg-slate-800 text-slate-600 px-8 py-3 rounded-xl font-bold hover:bg-slate-200 text-center flex items-center justify-center">إلغاء</a>
                    }
                    else
                    {
                        <a asp-controller="Dashboard" asp-action="IndexAr" class="bg-slate-100 dark:bg-slate-800 text-slate-600 px-8 py-3 rounded-xl font-bold hover:bg-slate-200 text-center flex items-center justify-center">إلغاء</a>
                    }
                </div>
            </form>
        </div>

        <!-- قسم الأمان — المصادقة الثنائية -->
        <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-100 dark:border-slate-800 mt-6">
            <h3 class="text-lg font-bold mb-6 border-r-4 border-primary pr-3 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">security</span> الأمان
            </h3>
            <div class="flex items-center justify-between p-4 bg-slate-50 dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700">
                <div class="flex items-center gap-4">
                    <div class="size-12 flex items-center justify-center rounded-xl @(is2faEnabled ? "bg-emerald-100 dark:bg-emerald-900/30" : "bg-slate-200 dark:bg-slate-700")">
                        <span class="material-symbols-outlined !text-2xl @(is2faEnabled ? "text-emerald-600" : "text-slate-400")">
                            @(is2faEnabled ? "verified_user" : "shield")
                        </span>
                    </div>
                    <div>
                        <h4 class="font-bold text-slate-900 dark:text-white">المصادقة الثنائية</h4>
                        <p class="text-sm text-slate-500 dark:text-slate-400">
                            @if (is2faEnabled)
                            {
                                <span class="inline-flex items-center gap-1 text-emerald-600 font-semibold">
                                    <span class="material-symbols-outlined text-xs">check_circle</span> مُفعّلة
                                </span>
                                <span> — حسابك محمي بالمصادقة الثنائية.</span>
                            }
                            else
                            {
                                <span class="text-slate-500">أضف طبقة أمان إضافية باستخدام تطبيق المصادقة.</span>
                            }
                        </p>
                    </div>
                </div>
                <div>
                    @if (is2faEnabled)
                    {
                        <form asp-controller="TwoFactor" asp-action="Disable" method="post" onsubmit="return confirm('هل أنت متأكد من رغبتك في تعطيل المصادقة الثنائية؟');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="h-10 px-5 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 font-bold rounded-lg text-sm hover:bg-red-100 transition-colors flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px]">remove_moderator</span> تعطيل
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="TwoFactor" asp-action="Setup" class="h-10 px-5 bg-primary text-white font-bold rounded-lg text-sm hover:bg-primary/90 transition-colors flex items-center gap-2 shadow-lg shadow-primary/20">
                            <span class="material-symbols-outlined text-[18px]">add_moderator</span> تفعيل
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
