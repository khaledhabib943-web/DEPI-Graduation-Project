@model FinalProject.Web.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "نسيت كلمة المرور";
    Layout = "_LayoutArabic";
}

<div class="flex-1 flex items-center justify-center p-6">
    <div class="w-full max-w-[480px] space-y-8">
        <div class="text-center md:text-right">
            <h1 class="text-4xl font-black mb-2">نسيت كلمة المرور</h1>
            <p class="text-slate-500">أدخل بريدك الإلكتروني لاستلام رابط إعادة تعيين كلمة المرور.</p>
        </div>

        <div class="bg-white dark:bg-slate-900 p-8 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
            @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
            {
                <div class="mb-4 p-3 rounded-lg bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 text-sm font-medium">
                    <span class="material-symbols-outlined text-sm align-middle ml-1">error</span> @Model.ErrorMessage
                </div>
            }

            <form asp-action="ForgotPasswordAr" method="post" class="space-y-6">
                <div class="space-y-2">
                    <label class="text-sm font-semibold">البريد الإلكتروني</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute text-slate-400 right-3 top-3">mail</span>
                        <input asp-for="Email" class="form-input w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 h-12 focus:ring-2 focus:ring-primary pr-11 pl-4" placeholder="name@company.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
                </div>

                <button type="submit" class="w-full h-12 bg-primary hover:bg-primary/90 text-white font-bold rounded-lg transition-colors flex items-center justify-center gap-2 shadow-lg shadow-primary/20">
                    <span>إرسال الرابط</span>
                    <span class="material-symbols-outlined text-[20px]">send</span>
                </button>
            </form>
        </div>

        <p class="text-center text-slate-500 dark:text-slate-400 text-sm">
            هل تتذكر كلمة المرور؟
            <a asp-controller="Account" asp-action="LoginAr" class="font-bold text-primary hover:underline underline-offset-4">تسجيل الدخول</a>
        </p>
    </div>
</div>
