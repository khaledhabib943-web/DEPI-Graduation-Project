@model FinalProject.Web.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "إعادة تعيين كلمة المرور";
    Layout = "_LayoutArabic";
}

<div class="flex-1 flex items-center justify-center p-6">
    <div class="w-full max-w-[480px] space-y-8">
        <div class="text-center md:text-right">
            <h1 class="text-4xl font-black mb-2">إعادة تعيين كلمة المرور</h1>
            <p class="text-slate-500">الرجاء إدخال كلمة المرور الجديدة أدناه.</p>
        </div>

        <div class="bg-white dark:bg-slate-900 p-8 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mb-4 p-3 rounded-lg bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 text-sm font-medium">
                    <div asp-validation-summary="All" class="text-red-500 text-xs"></div>
                </div>
            }

            <form asp-action="ResetPasswordAr" method="post" class="space-y-6">
                <input asp-for="Code" type="hidden" />

                <div class="space-y-2">
                    <label class="text-sm font-semibold">البريد الإلكتروني</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute text-slate-400 right-3 top-3">mail</span>
                        <input asp-for="Email" class="form-input w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 h-12 focus:ring-2 focus:ring-primary pr-11 pl-4" placeholder="name@company.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
                </div>

                <div class="space-y-2">
                    <label class="text-sm font-semibold">كلمة المرور الجديدة</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute text-slate-400 right-3 top-3">lock</span>
                        <input asp-for="Password" class="form-input w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 h-12 focus:ring-2 focus:ring-primary pr-11 pl-4" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Password" class="text-red-500 text-xs"></span>
                </div>

                <div class="space-y-2">
                    <label class="text-sm font-semibold">تأكيد كلمة المرور</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute text-slate-400 right-3 top-3">lock_clock</span>
                        <input asp-for="ConfirmPassword" class="form-input w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 h-12 focus:ring-2 focus:ring-primary pr-11 pl-4" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs"></span>
                </div>

                <button type="submit" class="w-full h-12 bg-primary hover:bg-primary/90 text-white font-bold rounded-lg transition-colors flex items-center justify-center gap-2 shadow-lg shadow-primary/20">
                    <span>إعادة تعيين</span>
                    <span class="material-symbols-outlined text-[20px]">lock_reset</span>
                </button>
            </form>
        </div>
    </div>
</div>
