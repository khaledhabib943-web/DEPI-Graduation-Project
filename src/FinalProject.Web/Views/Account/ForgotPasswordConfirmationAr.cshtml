@{
    ViewData["Title"] = "تأكيد نسيت كلمة المرور";
    Layout = "_LayoutArabic";
}

<div class="flex-1 flex items-center justify-center p-6">
    <div class="w-full max-w-[480px] space-y-8 text-center">
        <div class="w-20 h-20 bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="material-symbols-outlined text-4xl">mark_email_read</span>
        </div>
        
        <h1 class="text-slate-900 dark:text-white text-3xl font-black mb-2">تحقق من بريدك الإلكتروني</h1>
        <p class="text-slate-500 dark:text-slate-400 text-base font-normal">
            إذا كان هناك حساب مرتبط بالبريد الإلكتروني الذي أدخلته، فقد أرسلنا إليه رابط إعادة تعيين كلمة المرور. يرجى التحقق من صندوق الوارد.
        </p>

        <div class="mt-8">
            <a asp-controller="Account" asp-action="LoginAr" class="text-primary hover:text-primary/80 font-bold hover:underline underline-offset-4">
                العودة إلى تسجيل الدخول
            </a>
        </div>
    </div>
</div>
