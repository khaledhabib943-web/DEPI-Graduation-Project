@model FinalProject.Web.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="flex-1 flex items-center justify-center p-6">
    <div class="w-full max-w-[480px] space-y-8">
        <div class="text-center md:text-left">
            <h1 class="text-slate-900 dark:text-white text-4xl font-black leading-tight tracking-tight mb-2">Forgot Password</h1>
            <p class="text-slate-500 dark:text-slate-400 text-base font-normal">Enter your email address to receive a password reset link.</p>
        </div>

        <div class="bg-white dark:bg-slate-900 p-8 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
            @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
            {
                <div class="mb-4 p-3 rounded-lg bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 text-sm font-medium">
                    <span class="material-symbols-outlined text-sm align-middle mr-1">error</span> @Model.ErrorMessage
                </div>
            }

            <form asp-action="ForgotPassword" method="post" class="space-y-6">
                <div class="space-y-2">
                    <label asp-for="Email" class="text-slate-900 dark:text-slate-200 text-sm font-semibold leading-normal"></label>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute text-slate-400 left-3">mail</span>
                        <input asp-for="Email" class="form-input flex w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white h-12 focus:ring-2 focus:ring-primary focus:border-transparent transition-all placeholder:text-slate-400 pl-11 pr-4" placeholder="name@company.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
                </div>

                <button type="submit" class="w-full h-12 bg-primary hover:bg-primary/90 text-white font-bold rounded-lg transition-colors flex items-center justify-center gap-2 shadow-lg shadow-primary/20">
                    <span>Send Reset Link</span>
                    <span class="material-symbols-outlined text-[20px]">send</span>
                </button>
            </form>
        </div>

        <p class="text-center text-slate-500 dark:text-slate-400 text-sm">
            Remember your password?
            <a asp-controller="Account" asp-action="Login" class="font-bold text-primary hover:underline underline-offset-4">Sign In</a>
        </p>
    </div>
</div>
