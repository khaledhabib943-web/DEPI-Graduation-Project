@{
    ViewData["Title"] = "Forgot Password Confirmation";
}

<div class="flex-1 flex items-center justify-center p-6">
    <div class="w-full max-w-[480px] space-y-8 text-center">
        <div class="w-20 h-20 bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="material-symbols-outlined text-4xl">mark_email_read</span>
        </div>
        
        <h1 class="text-slate-900 dark:text-white text-3xl font-black leading-tight tracking-tight mb-2">Check your email</h1>
        <p class="text-slate-500 dark:text-slate-400 text-base font-normal">
            If an account exists for the email you entered, we have sent a password reset link to it. Please check your inbox.
        </p>

        <div class="mt-8">
            <a asp-controller="Account" asp-action="Login" class="text-primary hover:text-primary/80 font-bold hover:underline underline-offset-4">
                Return to Sign In
            </a>
        </div>
    </div>
</div>
