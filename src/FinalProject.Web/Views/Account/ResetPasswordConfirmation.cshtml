@{
    ViewData["Title"] = "Password Reset Successful";
}

<div class="flex-1 flex items-center justify-center p-6">
    <div class="w-full max-w-[480px] space-y-8 text-center">
        <div class="w-20 h-20 bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="material-symbols-outlined text-4xl">check_circle</span>
        </div>
        
        <h1 class="text-slate-900 dark:text-white text-3xl font-black leading-tight tracking-tight mb-2">Password Reset Successful</h1>
        <p class="text-slate-500 dark:text-slate-400 text-base font-normal">
            Your password has been successfully reset. You can now sign in with your new password.
        </p>

        <div class="mt-8">
            <a asp-controller="Account" asp-action="Login" class="inline-flex h-12 items-center justify-center bg-primary hover:bg-primary/90 text-white font-bold rounded-lg transition-colors px-6 gap-2 shadow-lg shadow-primary/20">
                <span>Sign In</span>
                <span class="material-symbols-outlined text-[20px]">login</span>
            </a>
        </div>
    </div>
</div>
