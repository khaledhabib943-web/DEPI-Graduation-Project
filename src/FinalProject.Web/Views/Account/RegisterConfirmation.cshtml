@{ ViewData["Title"] = "Check your email"; }

<div class="flex-1 flex items-center justify-center p-6 py-12">
    <div class="w-full max-w-[640px] space-y-8">
        <div class="text-center">
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-green-100 dark:bg-green-900/20 mb-6">
                <span class="material-symbols-outlined text-4xl text-green-600 dark:text-green-400">mail</span>
            </div>
            <h1 class="text-slate-900 dark:text-white text-4xl font-black leading-tight tracking-tight mb-2">Check your email</h1>
            <p class="text-slate-500 dark:text-slate-400 text-base">We've sent a confirmation link to your email address. Please check your inbox and click the link to verify your account.</p>
        </div>
        <div class="bg-white dark:bg-slate-900 p-8 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
            <div class="space-y-4">
                <div class="flex items-start gap-3">
                    <span class="material-symbols-outlined text-primary text-xl mt-0.5">info</span>
                    <p class="text-slate-600 dark:text-slate-400 text-sm">If you don't receive the email within a few minutes, please check your spam folder.</p>
                </div>
                <div class="flex items-start gap-3">
                    <span class="material-symbols-outlined text-primary text-xl mt-0.5">shield</span>
                    <p class="text-slate-600 dark:text-slate-400 text-sm">For security reasons, the confirmation link will expire in 24 hours.</p>
                </div>
            </div>
        </div>
        <p class="text-center text-slate-500 dark:text-slate-400 text-sm">Already confirmed your email? <a asp-controller="Account" asp-action="Login" class="font-bold text-primary hover:underline underline-offset-4">Sign In</a></p>
    </div>
</div>
