@model FinalProject.Web.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="flex-1 flex items-center justify-center p-6">
    <div class="w-full max-w-[480px] space-y-8">
        <div class="text-center md:text-left">
            <h1 class="text-slate-900 dark:text-white text-4xl font-black leading-tight tracking-tight mb-2">Reset Password</h1>
            <p class="text-slate-500 dark:text-slate-400 text-base font-normal">Please enter your new password below.</p>
        </div>

        <div class="bg-white dark:bg-slate-900 p-8 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mb-4 p-3 rounded-lg bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 text-sm font-medium">
                    <div asp-validation-summary="All" class="text-red-500 text-xs"></div>
                </div>
            }

            <form asp-action="ResetPassword" method="post" class="space-y-6">
                <input asp-for="Code" type="hidden" />

                <div class="space-y-2">
                    <label asp-for="Email" class="text-slate-900 dark:text-slate-200 text-sm font-semibold leading-normal"></label>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute text-slate-400 left-3">mail</span>
                        <input asp-for="Email" class="form-input flex w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white h-12 focus:ring-2 focus:ring-primary focus:border-transparent transition-all placeholder:text-slate-400 pl-11 pr-4" placeholder="name@company.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Password" class="text-slate-900 dark:text-slate-200 text-sm font-semibold leading-normal"></label>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute text-slate-400 left-3">lock</span>
                        <input asp-for="Password" value="@Model.Password" class="form-input flex w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white h-12 focus:ring-2 focus:ring-primary focus:border-transparent transition-all placeholder:text-slate-400 pl-11 pr-11" placeholder="••••••••" />
                        <button type="button" onclick="togglePassword(this)" class="absolute right-3 text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors" tabindex="-1">
                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-red-500 text-xs"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="ConfirmPassword" class="text-slate-900 dark:text-slate-200 text-sm font-semibold leading-normal"></label>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute text-slate-400 left-3">lock_clock</span>
                        <input asp-for="ConfirmPassword" value="@Model.ConfirmPassword" class="form-input flex w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white h-12 focus:ring-2 focus:ring-primary focus:border-transparent transition-all placeholder:text-slate-400 pl-11 pr-11" placeholder="••••••••" />
                        <button type="button" onclick="togglePassword(this)" class="absolute right-3 text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors" tabindex="-1">
                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs"></span>
                </div>

                <button type="submit" class="w-full h-12 bg-primary hover:bg-primary/90 text-white font-bold rounded-lg transition-colors flex items-center justify-center gap-2 shadow-lg shadow-primary/20">
                    <span>Reset Password</span>
                    <span class="material-symbols-outlined text-[20px]">lock_reset</span>
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function togglePassword(btn) {
    const input = btn.parentElement.querySelector('input');
    const icon = btn.querySelector('.material-symbols-outlined');
    if (input.type === 'password') {
        input.type = 'text';
        icon.textContent = 'visibility_off';
    } else {
        input.type = 'password';
        icon.textContent = 'visibility';
    }
}
</script>
}
