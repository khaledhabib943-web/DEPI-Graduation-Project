@model TrackRequestViewModel
@{
    ViewData["Title"] = "Track Request";
    var req = Model.Request;
    bool hasRated = ViewBag.HasAlreadyRated == true;
    var statusColor = req.Status switch {
        FinalProject.Domain.Enums.RequestStatus.Pending    => "bg-amber-100 text-amber-700",
        FinalProject.Domain.Enums.RequestStatus.InProgress => "bg-blue-100 text-blue-700",
        FinalProject.Domain.Enums.RequestStatus.Completed  => "bg-emerald-100 text-emerald-700",
        FinalProject.Domain.Enums.RequestStatus.Cancelled  => "bg-red-100 text-red-700",
        _ => "bg-slate-100 text-slate-600"
    };
}

<div class="flex-1 flex justify-center py-6 px-4 md:px-20">
    <div class="flex flex-col max-w-[960px] flex-1 gap-6">

        @if (TempData["Success"] != null)
        {
            <div class="p-4 rounded-xl bg-emerald-50 text-emerald-700 border border-emerald-200 flex items-center gap-3">
                <span class="material-symbols-outlined">check_circle</span>
                <span>@TempData["Success"]</span>
            </div>
        }

        <!-- Request Header -->
        <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-100 dark:border-slate-800">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
                <div>
                    <h1 class="text-2xl font-bold">Request #@req.RequestId</h1>
                    <p class="text-slate-500 mt-1">Created: @req.CreatedAt.ToString("MMM dd, yyyy h:mm tt")</p>
                    @if (req.PriceAtBooking > 0)
                    {
                        <p class="text-sm text-slate-500 mt-0.5">Price: <span class="font-bold text-primary">@req.PriceAtBooking.ToString("N2") EGP</span></p>
                    }
                </div>
                <span class="px-4 py-2 @statusColor font-bold rounded-full text-sm">@req.Status</span>
            </div>

            <!-- Visual Progress Timeline -->
            <div class="grid grid-cols-[48px_1fr] gap-x-4">
                @{
                    var statuses = new[] {
                        ("schedule",       "Pending",    "Waiting for worker to accept"),
                        ("thumb_up",       "Accepted",   "Technician has accepted your request"),
                        ("local_shipping", "In Transit", "Technician is on the way"),
                        ("place",          "Arrived",    req.IsArrivalConfirmedByCustomer ? "Arrival confirmed by you" : (req.IsWorkerArrived ? "Technician arrived — awaiting your confirmation" : "Technician at your location")),
                        ("handyman",       "Working",    req.IsWorkCompletedConfirmedByCustomer ? "You confirmed work is done" : "Work in progress"),
                        ("verified",       "Completed",  "Job successfully done")
                    };
                    int step = req.Status switch {
                        FinalProject.Domain.Enums.RequestStatus.Pending    => 0,
                        FinalProject.Domain.Enums.RequestStatus.InProgress => req.IsWorkCompletedConfirmedByCustomer ? 4 : req.IsArrivalConfirmedByCustomer ? 3 : req.IsWorkerArrived ? 2 : 2,
                        FinalProject.Domain.Enums.RequestStatus.Completed  => 5,
                        FinalProject.Domain.Enums.RequestStatus.Cancelled  => -1,
                        _ => -1
                    };
                }
                @for (int i = 0; i < statuses.Length; i++)
                {
                    var isActive  = i <= step;
                    var isCurrent = i == step;
                    <div class="flex flex-col items-center">
                        <div class="flex items-center justify-center size-10 rounded-full @(isActive ? "bg-primary text-white" : "bg-slate-100 dark:bg-slate-800 text-slate-400") @(isCurrent ? "ring-4 ring-primary/20" : "")">
                            <span class="material-symbols-outlined text-[20px]">@statuses[i].Item1</span>
                        </div>
                        @if (i < statuses.Length - 1) { <div class="w-1 @(isActive ? "bg-primary" : "bg-slate-200 dark:bg-slate-700") h-12"></div> }
                    </div>
                    <div class="@(i < statuses.Length - 1 ? "pb-8" : "")">
                        <p class="@(isCurrent ? "text-primary" : isActive ? "text-slate-900 dark:text-slate-100" : "text-slate-400") font-bold">@statuses[i].Item2</p>
                        <p class="text-slate-500 text-sm">@statuses[i].Item3</p>
                    </div>
                }
            </div>
        </div>

        <!-- Service Details -->
        <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-100 dark:border-slate-800">
            <h3 class="text-lg font-bold mb-4">Service Details</h3>
            <div class="flex flex-col gap-3">
                <div class="flex justify-between"><span class="text-slate-500">Category:</span><span class="font-semibold">@req.CategoryName</span></div>
                <div class="flex justify-between"><span class="text-slate-500">Technician:</span><span class="font-semibold">@req.WorkerName</span></div>
                <div class="flex justify-between"><span class="text-slate-500">Location:</span><span class="font-semibold">@req.LocationDetails</span></div>
                <div class="flex justify-between"><span class="text-slate-500">Date:</span><span class="font-semibold">@req.ScheduledDate.ToString("MMM dd, yyyy")</span></div>
                @if (!string.IsNullOrEmpty(req.Description))
                {
                    <div class="flex flex-col gap-1 pt-2 border-t border-slate-100 dark:border-slate-800">
                        <span class="text-slate-500 text-sm">Description:</span>
                        <p class="font-semibold text-sm">@req.Description</p>
                    </div>
                }
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <a asp-controller="Dashboard" asp-action="Index"
               class="w-full py-4 bg-primary text-white font-bold rounded-xl shadow-lg shadow-primary/20 flex items-center justify-center gap-2">
                <span class="material-symbols-outlined">dashboard</span> Back to Dashboard
            </a>

            @if (req.Status == FinalProject.Domain.Enums.RequestStatus.Completed)
            {
                @if (!hasRated)
                {
                    <a asp-controller="Review" asp-action="Create"
                       asp-route-requestId="@req.RequestId"
                       asp-route-workerId="@req.WorkerId"
                       asp-route-workerName="@req.WorkerName"
                       class="w-full py-4 bg-emerald-500 text-white font-bold rounded-xl flex items-center justify-center gap-2 shadow-lg shadow-emerald-500/20">
                        <span class="material-symbols-outlined">star</span> Rate Service
                    </a>
                }
                else
                {
                    <div class="w-full py-4 bg-slate-100 dark:bg-slate-800 text-slate-500 font-bold rounded-xl flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-amber-500">star</span> Service Already Rated
                    </div>
                }
            }
            else if (req.Status == FinalProject.Domain.Enums.RequestStatus.InProgress)
            {
                @* Customer confirms arrival when worker has arrived but not yet confirmed *@
                @if (req.IsWorkerArrived && !req.IsArrivalConfirmedByCustomer)
                {
                    <form asp-controller="ServiceRequest" asp-action="ConfirmArrival" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="requestId" value="@req.RequestId" />
                        <button type="submit"
                                class="w-full py-4 bg-blue-500 text-white font-bold rounded-xl flex items-center justify-center gap-2 shadow-lg shadow-blue-500/20 hover:bg-blue-600 transition-colors">
                            <span class="material-symbols-outlined">where_to_vote</span> Confirm Technician Arrived
                        </button>
                    </form>
                }
                @* Customer confirms work done — only after arrival is confirmed *@
                else if (req.IsArrivalConfirmedByCustomer && !req.IsWorkCompletedConfirmedByCustomer)
                {
                    <form asp-controller="ServiceRequest" asp-action="ConfirmWorkDone" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="requestId" value="@req.RequestId" />
                        <button type="submit"
                                class="w-full py-4 bg-emerald-500 text-white font-bold rounded-xl flex items-center justify-center gap-2 shadow-lg shadow-emerald-500/20 hover:bg-emerald-600 transition-colors">
                            <span class="material-symbols-outlined">task_alt</span> Confirm Work is Done
                        </button>
                    </form>
                }
                else if (req.IsWorkCompletedConfirmedByCustomer)
                {
                    <div class="w-full py-4 bg-emerald-50 dark:bg-emerald-900/20 text-emerald-700 font-bold rounded-xl flex items-center justify-center gap-2 border border-emerald-200">
                        <span class="material-symbols-outlined">check_circle</span> Work confirmed — awaiting completion mark
                    </div>
                }
            }
            else if (req.Status == FinalProject.Domain.Enums.RequestStatus.Pending)
            {
                <form asp-controller="ServiceRequest" asp-action="Cancel" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="requestId" value="@req.RequestId" />
                    <button class="w-full py-4 border-2 border-slate-200 dark:border-slate-800 text-slate-600 font-bold rounded-xl flex items-center justify-center gap-2 hover:bg-slate-50">
                        <span class="material-symbols-outlined">cancel</span> Cancel Request
                    </button>
                </form>
            }
            else if (req.Status == FinalProject.Domain.Enums.RequestStatus.Cancelled)
            {
                <a asp-controller="ServiceRequest" asp-action="SelectService"
                   class="w-full py-4 bg-slate-100 dark:bg-slate-800 text-slate-700 font-bold rounded-xl flex items-center justify-center gap-2 hover:bg-slate-200">
                    <span class="material-symbols-outlined">add_circle</span> Book New Service
                </a>
            }
        </div>
    </div>
</div>
