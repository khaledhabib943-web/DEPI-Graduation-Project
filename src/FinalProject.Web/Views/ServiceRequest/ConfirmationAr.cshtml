@model ConfirmationViewModel
@{ ViewData["Title"] = "تأكيد الطلب"; Layout = "_LayoutArabic"; }

<div class="flex-1 flex flex-col items-center py-8 px-4">
    <div class="w-full max-w-[640px] flex flex-col gap-8">
        <!-- Progress Bar -->
        <div class="flex flex-col gap-3 p-4 bg-white dark:bg-slate-900 rounded-xl shadow-sm">
            <div class="flex justify-between"><p class="font-bold">الخطوة 4 من 5</p><span class="text-primary font-bold text-sm bg-primary/10 px-2 py-1 rounded">100%</span></div>
            <div class="h-3 bg-slate-100 dark:bg-slate-800 rounded-full"><div class="h-full bg-primary rounded-full w-full"></div></div>
        </div>

        <!-- Success Icon -->
        <div class="flex flex-col items-center text-center py-6">
            <div class="size-24 bg-primary/10 text-primary rounded-full flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-5xl" style="font-variation-settings:'wght' 700">check_circle</span>
            </div>
            <h1 class="text-3xl font-extrabold mb-3">تم تأكيد طلبك!</h1>
            <p class="text-slate-600 dark:text-slate-400 max-w-md">
                شكراً لاستخدامك <strong>صلاحلي</strong>. طلب رقم <span class="font-bold text-primary">#@Model.Request.RequestId</span> تم استلامه. سيتواصل معك الفني قريباً.
            </p>
        </div>

        <!-- Order Summary -->
        <div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-100 dark:border-slate-800 overflow-hidden">
            <div class="p-5 border-b border-slate-100 dark:border-slate-800 bg-slate-50/50 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">receipt_long</span>
                <h2 class="text-lg font-bold">ملخص الطلب</h2>
            </div>
            <div class="p-6 flex flex-col gap-4">
                <div class="flex justify-between"><span class="text-slate-500">الخدمة:</span><span class="font-semibold">@Model.Request.CategoryName</span></div>
                <div class="flex justify-between"><span class="text-slate-500">التاريخ:</span><span class="font-semibold">@Model.Request.ScheduledDate.ToString("dd MMM yyyy")</span></div>
                <div class="flex justify-between"><span class="text-slate-500">الموقع:</span><span class="font-semibold">@Model.Request.LocationDetails</span></div>
                <div class="flex justify-between"><span class="text-slate-500">الحالة:</span><span class="font-semibold text-primary">قيد الانتظار</span></div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
            <a asp-controller="Dashboard" asp-action="IndexAr" class="flex-1 bg-primary text-white h-14 rounded-xl font-bold text-lg hover:bg-primary/90 flex items-center justify-center gap-2 shadow-lg shadow-primary/20">
                <span class="material-symbols-outlined">dashboard</span> العودة للرئيسية
            </a>
            <a asp-controller="ServiceRequest" asp-action="TrackRequestAr" asp-route-requestId="@Model.Request.RequestId"
               class="flex-1 bg-slate-100 dark:bg-slate-800 h-14 rounded-xl font-bold text-lg hover:bg-slate-200 flex items-center justify-center gap-2">
                <span class="material-symbols-outlined">visibility</span> تتبع الطلب
            </a>
        </div>
    </div>
</div>
